                            <type>DEPENDENT</type>
                            <key>mtr.hop.avg[{#HOP_IP}]</key>
                            <delay>0</delay>
                            <history>14d</history>
                            <value_type>FLOAT</value_type>
                            <trends>180d</trends>
                            <units>!ms</units>
                            <preprocessing>
                                <step>
                                    <type>JSONPATH</type>
                                    <parameters>
                                        <parameter>$.[?(@.count == &quot;{#HOP_ID}&quot;)][&quot;Avg&quot;].first()</parameter>
                                    </parameters>
                                </step>
                            </preprocessing>
                            <master_item>
                                <key>mtr.sh[{$FIRST_TTL} {HOST.IP}]</key>
                            </master_item>
